<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="min-h-screen bg-zinc-900 p-10 text-white">
        <div class="nav mb-10">    
            <a class="text-blue-500 text-lg" href="/read">Read Users</a>
        </div>

        <form action="/create" method="POST" class="flex flex-col gap-5 w-96">
            <h1 class="text-3xl tracking-tighter mb-3">Create User</h1>

            <input type="text" class="px-5 py-2 border-2 border-zinc-800 outline-none rounded-lg bg-transparent" name="name" placeholder="Name">
            <input type="text" class="px-5 py-2 border-2 border-zinc-800 outline-none rounded-lg bg-transparent" name="email" placeholder="email">
            <input type="text" class="px-5 py-2 border-2 border-zinc-800 outline-none rounded-lg bg-transparent" name="image" placeholder="image url">

            <input type="submit" class="px-5 py-2 ml-3 bg-blue-600 text-white border-blue-600 rounded-lg" value="Submit">
        </form>
    </div>
</body>
</html>