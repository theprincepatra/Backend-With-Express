<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="min-h-screen bg-zinc-900 p-10 text-white">
        <div class="nav mb-10">    
            <a class="text-blue-500 text-lg" href="/read">Back to Users</a>
        </div>

        <h1 class="text-4xl tracking-tighter mb-7">Edit User</h1>

        <div class="outside flex flex-row gap-10 ">
            <form action="/edit/<%= oneuser._id %>" method="POST" class="flex flex-col gap-6">
        
                <div class="obj flex flex-row gap-2">
                    <h4 class="py-4 text-gray-400">Change Name-</h4>
                    <input type="text" value="<%= oneuser.name %>" class="px-3 py-2 w-96 border-2 border-zinc-800 outline-none rounded-lg bg-transparent" name="changedname">
                </div>
                <div class="obj flex flex-row gap-2">
                    <h4 class="py-4 text-gray-400">Change Email-</h4>
                    <input type="text" value="<%= oneuser.email %>" class="px-3 py-2 w-96 border-2 border-zinc-800 outline-none rounded-lg bg-transparent" name="changedemail">
                </div>
                <div class="obj flex flex-row gap-2">
                    <h4 class="py-4 text-gray-400">Change Image-</h4>
                    <input type="text" value="<%= oneuser.image %>" class="px-3 py-2 w-96 border-2 border-zinc-800 outline-none rounded-lg bg-transparent" name="changedimage">
                </div>

                <input type="submit" value="Submit" class="mt-1 py-2 bg-blue-600 text-white border-blue-600 rounded-lg">
            </form>
        </div>

        
    </div>
</body>
</html>