<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="min-h-screen bg-zinc-900 p-10 text-white">

        <div class="nav mb-10">    
            <a class="text-blue-500 text-lg" href="/">Back to Home</a>
        </div>

        <h1 class="text-3xl tracking-tighter mb-3">All User</h1>
        <div class="users flex gap-3 flex-wrap">    
            <% users.forEach(function(user) { %>
                <div class="user w-60 p-4 bg-zinc-800 rounded-lg">

                    <div class="w-full h-52 rounded-lg bg-black">
                        <img class="w-full h-full object-cover" src="<%= user.image %>" alt="user img">
                    </div>
                    <h3 class="text-xl mt-3 tracking-tighter"><%= user.name %></h3>
                    <h5 class="text-zinc-500"><%= user.email %></h5>
                    <div class="flex mt-10 gap-3">
                        <a class="text-yellow-600" href="/edit/<%= user._id %>">Edit</a>
                        <a class="text-red-600" href="/delete/<%= user._id %>">Delete</a>
                    </div>
                    
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>