<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EDIT</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10">
    <div class="form p-7 text-white">
        <a href="/" class="text-blue-500 text-lg inline-block mb-8">Go back to home</a>
        
        <form action="/edit" method="post">
            <input class="block w-1/2 rounded-md outline-none px-5 py-2 bg-zinc-800" type="text" name="previous" value="<%= filename %>">
            <input class="block w-1/2 rounded-md outline-none px-5 py-2 bg-zinc-800 mt-2" type="text" placeholder="New Name" name="new" required>

            <input class="mt-4 bg-green-600 text-lg px-5 py-2 rounded-md" type="submit" value="Update Name">
        </form>
    </div>
</div>
</body>
</html>